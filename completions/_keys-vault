#compdef keys-vault

_keys-vault() {
    _arguments -s \
        '--dir=[Plaintext mount point]:directory:_directories' \
        '--cipher-dir=[Encrypted ciphertext directory]:directory:_directories' \
        '(-h --help)'{-h,--help}'[Show help]' \
        '--version[Show version]' \
        ':command:((
            init\:"Create encrypted volume"
            open\:"Mount vault"
            close\:"Unmount vault"
            status\:"Print vault state"
            passwd\:"Rotate passphrase"
        ))'
}

_keys-vault "$@"
