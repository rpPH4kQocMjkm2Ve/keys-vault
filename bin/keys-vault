#!/bin/bash
# keys-vault — FBE via gocryptfs + GNOME Keyring
#
# Commands:
#   init     — create encrypted volume, store passphrase in keyring
#   open     — mount (passphrase from keyring)
#   close    — unmount
#   status   — print state: open / locked / stale / not initialized
#   passwd   — rotate gocryptfs passphrase

set -euo pipefail

readonly VERSION="1.0.0"

# ── defaults ───────────────────────────────────────────────

PLAIN_DIR="${HOME}/keys"
CIPHER_DIR=""

# ── configuration ──────────────────────────────────────────

load_config() {
    local conf="$1"
    [[ -f "$conf" ]] || return 0

    local -a allowed=(PLAIN_DIR CIPHER_DIR)

    while IFS='=' read -r key value; do
        key="${key#"${key%%[![:space:]]*}"}"
        key="${key%"${key##*[![:space:]]}"}"

        value="${value#"${value%%[![:space:]]*}"}"
        value="${value%"${value##*[![:space:]]}"}"

        # Strip inline comments (space-hash)
        value="${value%% #*}"
        value="${value%"${value##*[![:space:]]}"}"

        [[ "$key" =~ ^#.*$ || -z "$key" ]] && continue

        local valid=0
        for a in "${allowed[@]}"; do
            [[ "$key" == "$a" ]] && { valid=1; break; }
        done

        if [[ $valid -eq 1 ]]; then
            # Strip surrounding quotes
            value="${value#\"}"
            value="${value%\"}"
            value="${value#\'}"
            value="${value%\'}"
            printf -v "$key" '%s' "$value"
        else
            printf 'keys-vault: unknown config key ignored: %s\n' "$key" >&2
        fi
    done < "$conf"
}

finalize_dirs() {
    PLAIN_DIR="${PLAIN_DIR//\$\{HOME\}/$HOME}"
    PLAIN_DIR="${PLAIN_DIR//\$HOME/$HOME}"
    PLAIN_DIR="${PLAIN_DIR/#\~/$HOME}"
    PLAIN_DIR=$(realpath -m "$PLAIN_DIR")

    if [[ -z "$CIPHER_DIR" ]]; then
        local parent base
        parent=$(dirname "$PLAIN_DIR")
        base=$(basename "$PLAIN_DIR")
        CIPHER_DIR="${parent}/.${base}.enc"
    else
        CIPHER_DIR="${CIPHER_DIR//\$\{HOME\}/$HOME}"
        CIPHER_DIR="${CIPHER_DIR//\$HOME/$HOME}"
        CIPHER_DIR="${CIPHER_DIR/#\~/$HOME}"
        CIPHER_DIR=$(realpath -m "$CIPHER_DIR")
    fi
}

# ── helpers ────────────────────────────────────────────────

die()            { printf 'keys-vault: %s\n' "$*" >&2; exit 1; }
is_initialized() { [[ -f "$CIPHER_DIR/gocryptfs.conf" ]]; }

is_mounted() {
    mountpoint -q "$PLAIN_DIR" 2>/dev/null
}

is_stale() {
    if grep -qF " ${PLAIN_DIR} fuse." /proc/mounts 2>/dev/null; then
        ! stat "$PLAIN_DIR" &>/dev/null
    else
        return 1
    fi
}

recover_stale() {
    is_stale || return 0
    printf 'keys-vault: recovering stale FUSE mount at %s\n' "$PLAIN_DIR" >&2
    fusermount -u "$PLAIN_DIR" 2>/dev/null \
        || fusermount -uz "$PLAIN_DIR" 2>/dev/null \
        || die "cannot unmount stale $PLAIN_DIR"
}

kr_attr() { printf 'keys-vault:%s' "$PLAIN_DIR"; }

kr_store() {
    local attr
    attr=$(kr_attr)
    printf '%s' "$1" \
        | secret-tool store \
            --label="keys-vault passphrase (${PLAIN_DIR})" \
            application "$attr"
}

kr_lookup() {
    local attr
    attr=$(kr_attr)
    timeout 5 secret-tool lookup application "$attr" 2>/dev/null
}

read_pass() {
    local pass pass2
    IFS= read -rsp "Passphrase: " pass; echo >&2
    [[ -n "$pass" ]] || die "empty passphrase"
    IFS= read -rsp "Confirm:    " pass2; echo >&2
    [[ "$pass" = "$pass2" ]] || die "passphrases do not match"
    printf '%s' "$pass"
}

gen_pass() { head -c 32 /dev/urandom | base64 | tr -d '\n'; }

choose_pass() {
    local pass choice
    printf '1) Generate random passphrase\n' >&2
    printf '2) Enter your own\n' >&2
    IFS= read -rp 'Choice [1/2]: ' choice

    case "$choice" in
        1)
            pass=$(gen_pass)
            cat >&2 <<EOF

Generated passphrase (save it — e.g. in KeePassXC):

    $pass

It will be stored in GNOME Keyring for automatic unlock.
EOF
            ;;
        2)  pass=$(read_pass) ;;
        *)  die "invalid choice" ;;
    esac
    printf '%s' "$pass"
}

# ── commands ───────────────────────────────────────────────

cmd_init() {
    is_initialized && die "already initialized ($CIPHER_DIR)"

    if [[ -d "$PLAIN_DIR" ]] \
        && [[ -n "$(ls -A "$PLAIN_DIR" 2>/dev/null)" ]]; then
        cat >&2 <<EOF
keys-vault: $PLAIN_DIR is not empty.
Move or back up its contents first, then run init again.
After 'keys-vault init' and 'keys-vault open' you can copy them into the mounted volume.
EOF
        exit 1
    fi

    local pass
    pass=$(choose_pass) || die "passphrase input failed"
    [[ -n "$pass" ]] || die "empty passphrase"

    mkdir -p "$CIPHER_DIR"

    printf '%s' "$pass" \
        | gocryptfs -init -q -- "$CIPHER_DIR" \
        || { rm -rf "$CIPHER_DIR"; die "gocryptfs -init failed"; }

    kr_store "$pass"

    mkdir -p "$PLAIN_DIR"
    printf '\nInitialized. Run: keys-vault open\n' >&2
}

cmd_open() {
    recover_stale
    is_mounted && return 0
    is_initialized || return 0

    mkdir -p "$PLAIN_DIR"

    local pass
    pass=$(kr_lookup) \
        || die "keyring lookup failed (is gnome-keyring unlocked?)"
    [[ -n "$pass" ]] || die "empty passphrase in keyring"

    printf '%s' "$pass" \
        | gocryptfs -q -- "$CIPHER_DIR" "$PLAIN_DIR" \
        || die "mount failed"
}

cmd_close() {
    if is_stale; then
        fusermount -u "$PLAIN_DIR" 2>/dev/null \
            || fusermount -uz "$PLAIN_DIR" 2>/dev/null \
            || die "cannot unmount stale $PLAIN_DIR"
        return 0
    fi

    is_mounted || return 0

    fusermount -u "$PLAIN_DIR" 2>/dev/null \
        || fusermount -u -z "$PLAIN_DIR" \
        || die "unmount failed"
}

cmd_status() {
    if ! is_initialized; then
        echo "not initialized"
    elif is_stale; then
        echo "stale"
    elif is_mounted; then
        echo "open"
    else
        echo "locked"
    fi
}

cmd_passwd() {
    is_initialized || die "not initialized — run: keys-vault init"

    local old new
    old=$(kr_lookup) || die "cannot read current passphrase from keyring"

    new=$(choose_pass) || die "passphrase input failed"
    [[ -n "$new" ]] || die "empty passphrase"

    printf '%s\n%s\n' "$old" "$new" \
        | gocryptfs -passwd -q -- "$CIPHER_DIR" \
        || die "gocryptfs -passwd failed"

    kr_store "$new"
    printf 'Passphrase rotated and updated in keyring.\n' >&2
}

usage() {
    cat <<EOF
Usage: keys-vault [options] <command>

Commands:
    init     Create encrypted volume, store passphrase in keyring
    open     Mount vault (passphrase from keyring)
    close    Unmount vault
    status   Print state: open / locked / stale / not initialized
    passwd   Rotate gocryptfs passphrase and update keyring

Options:
    --dir=PATH         Plaintext mount point (default: ~/keys)
    --cipher-dir=PATH  Encrypted ciphertext directory
                       (default: derived from --dir)
    -h, --help         Show this help
    --version          Show version

Configuration:
    /etc/keys-vault.conf                             System defaults
    \${XDG_CONFIG_HOME:-~/.config}/keys-vault.conf    User overrides

    Set PLAIN_DIR and/or CIPHER_DIR in config files.
    CLI flags take precedence over config files.
EOF
}

# ── main ───────────────────────────────────────────────────

main() {
    load_config "/etc/keys-vault.conf"
    load_config "${XDG_CONFIG_HOME:-${HOME}/.config}/keys-vault.conf"

    local cmd=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --dir=*)        PLAIN_DIR="${1#*=}"; shift ;;
            --dir)          PLAIN_DIR="${2:?--dir requires a value}"; shift 2 ;;
            --cipher-dir=*) CIPHER_DIR="${1#*=}"; shift ;;
            --cipher-dir)   CIPHER_DIR="${2:?--cipher-dir requires a value}"; shift 2 ;;
            --version)      printf 'keys-vault %s\n' "$VERSION"; exit 0 ;;
            -h|--help)      usage; exit 0 ;;
            -*)             die "unknown option: $1" ;;
            *)
                [[ -z "$cmd" ]] || die "unexpected argument: $1"
                cmd="$1"; shift
                ;;
        esac
    done

    finalize_dirs

    case "$cmd" in
        init)   cmd_init   ;;
        open)   cmd_open   ;;
        close)  cmd_close  ;;
        status) cmd_status ;;
        passwd) cmd_passwd ;;
        "")     usage >&2; exit 1 ;;
        *)      die "unknown command: $cmd" ;;
    esac
}

if [[ -z "${_KEYS_VAULT_NO_MAIN:-}" ]]; then
    main "$@"
fi
